# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# CLI (optional; for local dev use REPLAYLY_API_URL=http://localhost:3000)
# REPLAYLY_API_URL=https://api.replayly.dev

# JWT (generate with: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# PostgreSQL (matches docker-compose)
DATABASE_URL=postgresql://replayly:replayly_dev_password@localhost:5432/replayly

# MongoDB (matches docker-compose; authSource=admin required for init user)
MONGODB_URI=mongodb://replayly:replayly_dev_password@localhost:27017/replayly?authSource=admin

# Redis
REDIS_URL=redis://localhost:6379

# MinIO (S3-compatible)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=replayly
S3_SECRET_KEY=replayly_dev_password
S3_BUCKET=replayly-events
S3_REGION=us-east-1

# OpenSearch
OPENSEARCH_URL=http://localhost:9200

# GitHub (for release tracking and webhooks)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=

# Real-time (Phase 8)
WS_PORT=3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Alerts – Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=alerts@replayly.dev

# Team invitations (optional; defaults to invitations@replayly.dev)
RESEND_INVITATION_FROM_EMAIL=invitations@replayly.dev
